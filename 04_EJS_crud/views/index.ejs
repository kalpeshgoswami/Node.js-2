<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>

    <h2>Name List</h2>

    <a href="/add"> Add Name</a>


    <ul>
        <% studentList.forEach((s)=> {%>

            <li>
